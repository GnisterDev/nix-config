input {
  keyboard {
    xkb {
      layout "no"
    }

    repeat-delay 200
    repeat-rate  30
  }

  touchpad {
    tap
    dwt
    natural-scroll
    accel-speed 0.2
    accel-profile "adaptive"
    click-method "clickfinger"
  }

  mouse {
    accel-profile "flat"
    accel-speed 0.0
  }

  tablet {
    map-to-output "eDP-1"
  }

  touch {
    map-to-output "eDP-1"
  }
}
